@model MVCApplication.Models.AndInTheDarknessBindThem
@{
    ViewData["Title"] = "My Profile";
}

@section Styles {
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
}

<div class="profile-container">
    @if (Model.User != null)
    {
        <!-- Header -->
        <div class="profile-header">
            <div class="profile-avatar">
                @if (!string.IsNullOrEmpty(Model.User.Username))
                {
                    @Model.User.Username.Substring(0, 1).ToUpper()
                }
                else
                {
                    <span>👤</span>
                }
            </div>
            <h1 class="profile-title">@Model.User.FullName</h1>
            <p class="profile-subtitle">@Model.User.Email</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="alert error">
                <strong>⚠️ Error:</strong> @Model.Error
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.Success))
        {
            <div class="alert success">
                <strong>✓ Success:</strong> @Model.Success
            </div>
        }

        <div class="alert error" id="validationErrors" style="display: none;">
            <strong>⚠️ Error:</strong> Please fix the errors below.
        </div>

        <!-- Stats Section -->
        <div class="stats-section">
            <div class="stat-card primary">
                <div class="stat-number">@(Model.Bookings?.Count ?? 0)</div>
                <div class="stat-label">Bookings</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">
                    @if (!string.IsNullOrEmpty(Model.User.Role))
                    {
                        <span class="role-badge @(Model.User.Role == "admin" ? "admin" : "user")">
                            @Model.User.Role
                        </span>
                    }
                </div>
                <div class="stat-label">Account Type</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">
                    @if (Model.User.Id > 0)
                    {
                        <span>✓</span>
                    }
                </div>
                <div class="stat-label">Verified</div>
            </div>
        </div>

        <!-- Profile Information -->
        <div class="profile-card">
            <div class="profile-section">
                <h2 class="section-title">
                    <span class="section-icon">👤</span>
                    Personal Information
                </h2>
                <div class="info-grid">
                    <div class="info-item">
                        <span class="info-label">Full Name</span>
                        <span class="info-value">@Model.User.FullName</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Username</span>
                        <span class="info-value">@Model.User.Username</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Email Address</span>
                        <span class="info-value">@Model.User.Email</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Account ID</span>
                        <span class="info-value">#@Model.User.Id</span>
                    </div>
                </div>
            </div>

            <div class="profile-section">
                <h2 class="section-title">
                    <span class="section-icon">✏️</span>
                    Edit Profile
                </h2>

                <form method="post" action="/Dashboard/Profile" class="profile-form" id="profileForm">
                    @Html.AntiForgeryToken()

                    <div class="info-grid">
                        <div class="info-item">
                            <label class="info-label" for="Username">Username</label>
                            <input class="profile-input"
                                   type="text"
                                   id="Username"
                                   name="Username"
                                   value="@Model.User.Username" />
                            <span class="error-message" id="usernameError"></span>
                        </div>

                        <div class="info-item">
                            <label class="info-label" for="FullName">Full Name</label>
                            <input class="profile-input"
                                   type="text"
                                   id="FullName"
                                   name="FullName"
                                   value="@Model.User.FullName" />
                            <span class="error-message" id="fullNameError"></span>
                        </div>

                        <div class="info-item">
                            <label class="info-label" for="Email">Email Address</label>
                            <input class="profile-input"
                                   type="email"
                                   id="Email"
                                   name="Email"
                                   value="@Model.User.Email" />
                            <span class="error-message" id="emailError"></span>
                        </div>

                        <div class="info-item">
                            <span class="info-label">Role</span>
                            <span class="info-value">
                                <span class="role-badge @(Model.User.Role == "admin" ? "admin" : "user")">
                                    @Model.User.Role
                                </span>
                            </span>
                        </div>
                    </div>

                    <div class="profile-actions">
                        <button type="submit" class="btn btn-primary">
                            💾 Save Profile
                        </button>
                        <a href="/Dashboard/MyBookings" class="btn btn-secondary">
                            🎫 View My Bookings
                        </a>
                        <a href="/Dashboard" class="btn btn-secondary">
                            ← Back to Dashboard
                        </a>
                    </div>
                </form>
            </div>

            <div class="profile-section">
                <h2 class="section-title">
                    <span class="section-icon">🔐</span>
                    Account Details
                </h2>
                <div class="info-grid">
                    <div class="info-item">
                        <span class="info-label">Role</span>
                        <span class="info-value">
                            <span class="role-badge @(Model.User.Role == "admin" ? "admin" : "user")">
                                @Model.User.Role
                            </span>
                        </span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Account Status</span>
                        <span class="info-value" style="color: #2e7d32;">
                            ✓ Active
                        </span>
                    </div>
                </div>
            </div>

            <div class="profile-actions">
                <a href="/Dashboard" class="btn btn-secondary">
                    ← Back to Dashboard
                </a>
                <a href="/Dashboard/MyBookings" class="btn btn-primary">
                    🎫 View My Bookings
                </a>
                <a href="/Feedback" class="btn btn-secondary">
                    💬 Contact Support
                </a>
            </div>
        </div>

        <div class="profile-card">
            <div class="profile-section">
                <h2 class="section-title">
                    <span class="section-icon">⚡</span>
                    Quick Actions
                </h2>
                <div class="profile-actions quick-actions">
                    <a href="/Events" class="btn btn-secondary">
                        📅 Browse Events
                    </a>
                    <a href="/Events/Create" class="btn btn-primary">
                        ➕ Create Event
                    </a>
                    @if (Model.User.Role == "admin")
                    {
                        <a href="/Admin/Users" class="btn btn-danger">
                            🛡️ Admin Panel
                        </a>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="alert error">
                <strong>⚠️ Error:</strong> @Model.Error
            </div>
        }

        <div class="error-state">
            <div class="error-state-icon">❌</div>
            <h2>Profile Not Found</h2>
            <p>We couldn't load your profile information.</p>
            <a href="/Dashboard" class="btn btn-primary">
                ← Return to Dashboard
            </a>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/validation-helpers.js"></script>
    <script src="~/js/profile-validation.js"></script>
}
