@model MVCApplication.Models.AndInTheDarknessBindThem

@{
    ViewData["Title"] = "Admin - Events";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-events.css" asp-append-version="true" />
}

<div class="admin-events-page">
    <div class="admin-events-header">
        <h1 class="admin-events-title">Manage Events</h1>
        <p class="admin-events-subtitle">
            Create, update, and remove community events from one place.
        </p>
    </div>

    @if (!Model.IsAdmin)
    {
        <div class="admin-message admin-message-error">
            You do not have permission to view this page.
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="admin-message admin-message-error">@Model.Error</div>
        }

        @if (!string.IsNullOrEmpty(Model.Success))
        {
            <div class="admin-message admin-message-success">@Model.Success</div>
        }

        <section class="admin-panel">
            <h2 class="admin-panel-title">Create Event</h2>

            <form method="post" action="/Admin/Events" class="admin-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="action" value="create" />

                <div class="admin-field">
                    <label class="admin-label" for="singleEvent_Title">Title</label>
                    <input id="singleEvent_Title"
                           class="admin-input"
                           type="text"
                           name="singleEvent.Title"
                           placeholder="Event title"
                           required />
                </div>

                <div class="admin-field">
                    <label class="admin-label" for="singleEvent_Description">Description</label>
                    <textarea id="singleEvent_Description"
                              class="admin-textarea"
                              name="singleEvent.Description"
                              placeholder="Event description"></textarea>
                </div>

                <div class="admin-field-grid">
                    <div class="admin-field">
                        <label class="admin-label" for="singleEvent_EventDate">Event Date</label>
                        <input id="singleEvent_EventDate"
                               class="admin-input"
                               type="datetime-local"
                               name="singleEvent.EventDate"
                               required />
                    </div>

                    <div class="admin-field">
                        <label class="admin-label" for="singleEvent_Location">Location</label>
                        <input id="singleEvent_Location"
                               class="admin-input"
                               type="text"
                               name="singleEvent.Location"
                               placeholder="Location" />
                    </div>
                </div>

                <div class="admin-actions">
                    <button type="submit" class="admin-btn admin-btn-primary">Create Event</button>
                    <button type="reset" class="admin-btn admin-btn-secondary">Reset</button>
                </div>
            </form>
        </section>

        <section class="admin-panel">
            <div class="admin-panel-heading">
                <h2 class="admin-panel-title">Existing Events</h2>
                <p class="admin-panel-help">Delete events in bulk or edit them below.</p>
            </div>

            @if (Model.Events is null || !Model.Events.Any())
            {
                <div class="admin-empty-state">
                    No events available.
                </div>
            }
            else
            {
                <form method="post" action="/Admin/Events" class="admin-delete-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="action" value="delete" />

                    <div class="admin-event-list">
                        @for (var i = 0; i < Model.Events.Count; i++)
                        {
                            var ev = Model.Events[i];

                            <label class="admin-delete-card">
                                <input type="checkbox" name="id" value="@ev.Id" />
                                <span class="admin-delete-content">
                                    <strong>@ev.Title</strong>
                                    <small>@ev.EventDate.ToString("MMM dd, yyyy h:mm tt")</small>
                                    <em>@ev.Location</em>
                                </span>
                            </label>
                        }
                    </div>

                    <div class="admin-actions">
                        <button type="submit" class="admin-btn admin-btn-danger">Delete Selected</button>
                    </div>
                </form>

                <hr class="admin-divider" />

                <form method="post" action="/Admin/Events" class="admin-update-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="action" value="update" />

                    <div class="admin-edit-grid">
                        @for (var i = 0; i < Model.Events.Count; i++)
                        {
                            var ev = Model.Events[i];

                            <article class="admin-edit-card">
                                <input type="hidden" name="events[@i].Id" value="@ev.Id" />

                                <div class="admin-card-meta">
                                    <span class="admin-badge">Event</span>
                                    <span class="admin-date">@ev.EventDate.ToString("MMMM dd, yyyy")</span>
                                </div>

                                <div class="admin-field">
                                    <label class="admin-label" for="events_@(i)__Title">Title</label>
                                    <input id="events_@(i)__Title"
                                           class="admin-input"
                                           type="text"
                                           name="events[@i].Title"
                                           value="@ev.Title"
                                           required />
                                </div>

                                <div class="admin-field">
                                    <label class="admin-label" for="events_@(i)__Description">Description</label>
                                    <textarea id="events_@(i)__Description"
                                              class="admin-textarea"
                                              name="events[@i].Description">@ev.Description</textarea>
                                </div>

                                <div class="admin-field-grid">
                                    <div class="admin-field">
                                        <label class="admin-label" for="events_@(i)__EventDate">Event Date</label>
                                        <input id="events_@(i)__EventDate"
                                               class="admin-input"
                                               type="datetime-local"
                                               name="events[@i].EventDate"
                                               value="@(ev.EventDate.ToString("yyyy-MM-ddTHH:mm"))"
                                               required />
                                    </div>

                                    <div class="admin-field">
                                        <label class="admin-label" for="events_@(i)__Location">Location</label>
                                        <input id="events_@(i)__Location"
                                               class="admin-input"
                                               type="text"
                                               name="events[@i].Location"
                                               value="@ev.Location" />
                                    </div>
                                </div>
                            </article>
                        }
                    </div>

                    <div class="admin-actions">
                        <button type="submit" class="admin-btn admin-btn-primary">Save Updates</button>
                    </div>
                </form>
            }
        </section>
    }
</div>
