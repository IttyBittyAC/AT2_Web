@model MVCApplication.Models.AndInTheDarknessBindThem

@{
    ViewData["Title"] = "Admin - Users";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-users.css" asp-append-version="true" />
}

<div class="admin-users-page">
    <div class="admin-users-header">
        <h1 class="admin-users-title">Manage Users</h1>
        <p class="admin-users-subtitle">
            Create new users, update account details, and remove users when needed.
        </p>
    </div>

    @if (!Model.IsAdmin)
    {
        <div class="admin-message admin-message-error">
            You do not have permission to view this page.
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="admin-message admin-message-error">@Model.Error</div>
        }

        @if (!string.IsNullOrEmpty(Model.Success))
        {
            <div class="admin-message admin-message-success">@Model.Success</div>
        }

        <section class="admin-panel">
            <h2 class="admin-panel-title">Create User</h2>

            <form method="post" action="/Admin/Users" class="admin-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="action" value="create" />

                <div class="admin-field-grid">
                    <div class="admin-field">
                        <label class="admin-label" for="user_Username">Username</label>
                        <input id="user_Username"
                               class="admin-input"
                               type="text"
                               name="user.Username"
                               placeholder="username" />
                    </div>

                    <div class="admin-field">
                        <label class="admin-label" for="user_FullName">Full Name</label>
                        <input id="user_FullName"
                               class="admin-input"
                               type="text"
                               name="user.FullName"
                               placeholder="Full name" />
                    </div>
                </div>

                <div class="admin-field-grid">
                    <div class="admin-field">
                        <label class="admin-label" for="user_Email">Email</label>
                        <input id="user_Email"
                               class="admin-input"
                               type="email"
                               name="user.Email"
                               placeholder="email@example.com" />
                    </div>

                    <div class="admin-field">
                        <label class="admin-label" for="user_Role">Role</label>
                        <select id="user_Role" class="admin-select" name="user.Role">
                            <option value="user">user</option>
                            <option value="admin">admin</option>
                        </select>
                    </div>
                </div>

                <div class="admin-field">
                    <label class="admin-label" for="user_PasswordHash">Password</label>
                    <input id="user_PasswordHash"
                           class="admin-input"
                           type="password"
                           name="user.PasswordHash"
                           placeholder="password (optional)" />
                </div>

                <div class="admin-actions">
                    <button type="submit" class="admin-btn admin-btn-primary">Create User</button>
                    <button type="reset" class="admin-btn admin-btn-secondary">Reset</button>
                </div>
            </form>
        </section>

        <section class="admin-panel">
            <div class="admin-panel-heading">
                <h2 class="admin-panel-title">Existing Users</h2>
                <p class="admin-panel-help">Update user details below or select users to delete.</p>
            </div>

            @if (Model.Users == null || !Model.Users.Any())
            {
                <div class="admin-empty-state">
                    No users found.
                </div>
            }
            else
            {
                <form method="post" action="/Admin/Users" id="usersForm" class="admin-update-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="action" name="action" value="" />

                    <div class="admin-select-all">
                        <label class="admin-checkbox-label" for="selectAll">
                            <input type="checkbox" id="selectAll" />
                            <span>Select all users</span>
                        </label>
                    </div>

                    <div class="admin-user-grid">
                        @for (var i = 0; i < Model.Users.Count; i++)
                        {
                            var u = Model.Users[i];

                            <article class="admin-user-card">
                                <div class="admin-user-card-top">
                                    <label class="admin-checkbox-label" for="rowCheck_@u.Id">
                                        <input type="checkbox" id="rowCheck_@u.Id" name="id" value="@u.Id" class="rowCheck" />
                                        <span>Select user</span>
                                    </label>

                                    <span class="admin-user-role-badge @(u.Role == "admin" ? "is-admin" : "is-user")">
                                        @u.Role
                                    </span>
                                </div>

                                <input type="hidden" name="users[@i].Id" value="@u.Id" />

                                <div class="admin-field">
                                    <label class="admin-label" for="users_@(i)__Username">Username</label>
                                    <input id="users_@(i)__Username"
                                           class="admin-input"
                                           type="text"
                                           name="users[@i].Username"
                                           value="@u.Username" />
                                </div>

                                <div class="admin-field">
                                    <label class="admin-label" for="users_@(i)__FullName">Full Name</label>
                                    <input id="users_@(i)__FullName"
                                           class="admin-input"
                                           type="text"
                                           name="users[@i].FullName"
                                           value="@u.FullName" />
                                </div>

                                <div class="admin-field">
                                    <label class="admin-label" for="users_@(i)__Email">Email</label>
                                    <input id="users_@(i)__Email"
                                           class="admin-input"
                                           type="email"
                                           name="users[@i].Email"
                                           value="@u.Email" />
                                </div>

                                <div class="admin-field">
                                    <label class="admin-label" for="users_@(i)__Role">Role</label>
                                    <select id="users_@(i)__Role" class="admin-select" name="users[@i].Role">
                                        <option value="user" selected="@(u.Role == "user")">user</option>
                                        <option value="admin" selected="@(u.Role == "admin")">admin</option>
                                    </select>
                                </div>
                            </article>
                        }
                    </div>

                    <div class="admin-actions">
                        <button type="submit"
                                class="admin-btn admin-btn-primary"
                                onclick="document.getElementById('action').value='update'">
                            Save Changes
                        </button>

                        <button type="submit"
                                class="admin-btn admin-btn-danger"
                                onclick="document.getElementById('action').value='delete'">
                            Delete Selected
                        </button>
                    </div>
                </form>
            }
        </section>
    }
</div>

@section Scripts {
    <script>
        document.getElementById("selectAll")?.addEventListener("change", function (e) {
            const checked = e.target.checked;
            document.querySelectorAll(".rowCheck").forEach(function (cb) {
                cb.checked = checked;
            });
        });
    </script>
}