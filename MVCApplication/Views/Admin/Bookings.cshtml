@model MVCApplication.Models.AndInTheDarknessBindThem

@{
    ViewData["Title"] = "Admin - Bookings";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-bookings.css" asp-append-version="true" />
}

<div class="admin-bookings-page">
    <header class="admin-bookings-header">
        <h1 class="admin-bookings-title">Bookings</h1>
        <p class="admin-bookings-subtitle">Create, update, and remove bookings for events. Use the update area to edit individual records or select multiple bookings to delete.</p>
    </header>

    @if (!Model.IsAdmin)
    {
        <div class="admin-message admin-message-error">
            You do not have permission to view this page.
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="admin-message admin-message-error">@Model.Error</div>
        }

        @if (!string.IsNullOrEmpty(Model.Success))
        {
            <div class="admin-message admin-message-success">@Model.Success</div>
        }

        <section class="admin-panel" aria-labelledby="create-booking-title">
            <h2 id="create-booking-title" class="admin-panel-title">Create New Booking</h2>

            <form class="admin-form" method="post" action="/Admin/Bookings">
                @Html.AntiForgeryToken()
                <input type="hidden" name="action" value="create" />

                <div class="admin-field">
                    <label class="admin-label">Full name</label>
                    <input class="admin-input" type="text" name="booking.FullName" placeholder="Your full name" required />
                </div>

                <div class="admin-field">
                    <label class="admin-label">Email</label>
                    <input class="admin-input" type="email" name="booking.Email" placeholder="you@example.com" required />
                </div>

                <div class="admin-field">
                    <label class="admin-label">Booking date</label>
                    <input class="admin-input" type="datetime-local" name="booking.BookingDate" required />
                </div>

                <div class="admin-actions">
                    <button type="submit" class="admin-btn admin-btn-primary">Create Booking</button>
                    <button type="reset" class="admin-btn admin-btn-secondary">Reset</button>
                </div>
            </form>
        </section>

        <section class="admin-panel" aria-labelledby="manage-bookings-title">
            <h2 id="manage-bookings-title" class="admin-panel-title">Manage Bookings</h2>

            @if (Model.Bookings is null || !Model.Bookings.Any())
            {
                <div class="admin-empty-state">No bookings available.</div>
            }
            else
            {
                <!-- Bulk delete using a compact list styled as cards -->
                <form method="post" action="/Admin/Bookings">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="action" value="delete" />

                    <div class="admin-booking-list" role="list">
                        @for (var i = 0; i < Model.Bookings.Count; i++)
                        {
                            var booking = Model.Bookings[i];
                            <label class="admin-booking-card" role="listitem">
                                <input type="checkbox" name="id" value="@booking.Id" />
                                <div class="admin-booking-content">
                                    <strong>@booking.FullName</strong>
                                    <small>@booking.Email</small>
                                    <small class="admin-date">@booking.BookingDate.ToString("yyyy-MM-dd HH:mm")</small>
                                </div>
                                <span class="admin-badge">#@booking.Id</span>
                            </label>
                        }
                    </div>

                    <div class="admin-actions" style="margin-top:16px;">
                        <button type="submit" class="admin-btn admin-btn-danger">Delete selected</button>
                    </div>
                </form>

                <hr class="admin-divider" />

                <!-- Update block: editable cards per booking -->
                <form method="post" action="/Admin/Bookings">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="action" value="update" />

                    <div class="admin-edit-grid">
                        @for (var i = 0; i < Model.Bookings.Count; i++)
                        {
                            var booking = Model.Bookings[i];
                            <div class="admin-edit-card">
                                <div class="admin-card-meta">
                                    <div>
                                        <strong>@booking.FullName</strong>
                                        <div class="admin-date">ID: @booking.Id</div>
                                    </div>
                                    <span class="admin-badge">Event #@booking.EventId</span>
                                </div>

                                <input type="hidden" name="bookings[@i].Id" value="@booking.Id" />
                                <input type="hidden" name="bookings[@i].UserId" value="@booking.UserId" />
                                <input type="hidden" name="bookings[@i].EventId" value="@booking.EventId" />

                                <div class="admin-field">
                                    <label class="admin-label">Full name</label>
                                    <input class="admin-input" type="text" name="bookings[@i].FullName" value="@booking.FullName" required />
                                </div>

                                <div class="admin-field">
                                    <label class="admin-label">Email</label>
                                    <input class="admin-input" type="email" name="bookings[@i].Email" value="@booking.Email" required />
                                </div>

                                <div class="admin-field">
                                    <label class="admin-label">Booking date</label>
                                    <input class="admin-input" type="datetime-local" name="bookings[@i].BookingDate" value="@(booking.BookingDate.ToString("yyyy-MM-ddTHH:mm"))" required />
                                </div>
                            </div>
                        }
                    </div>

                    <div class="admin-actions" style="margin-top:14px;">
                        <button type="submit" class="admin-btn admin-btn-primary">Save updates</button>
                    </div>
                </form>
            }
        </section>
    }
</div>