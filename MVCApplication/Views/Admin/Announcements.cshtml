@model MVCApplication.Models.AndInTheDarknessBindThem

@{
    ViewData["Title"] = "Admin - Announcements";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-announcements.css" asp-append-version="true" />
}

<div class="admin-announcements-page">
    <div class="admin-announcements-header">
        <h1 class="admin-announcements-title">Manage Announcements</h1>
        <p class="admin-announcements-subtitle">
            Create, update, and remove announcements shown across the site.
        </p>
    </div>

    @if (!Model.IsAdmin)
    {
        <div class="admin-message admin-message-error">
            You do not have permission to view this page.
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="admin-message admin-message-error">@Model.Error</div>
        }

        @if (!string.IsNullOrEmpty(Model.Success))
        {
            <div class="admin-message admin-message-success">@Model.Success</div>
        }

        <section class="admin-panel">
            <h2 class="admin-panel-title">Create Announcement</h2>

            <form method="post" action="/Admin/Announcements" class="admin-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="action" value="create" />

                <div class="admin-field">
                    <label for="announcementTitle" class="admin-label">Title</label>
                    <input id="announcementTitle"
                           class="admin-input"
                           type="text"
                           name="announcement.Title"
                           value="@Model.Announcement?.Title"
                           placeholder="Announcement title"
                           required />
                </div>

                <div class="admin-field">
                    <label for="announcementMessage" class="admin-label">Message</label>
                    <textarea id="announcementMessage"
                              class="admin-textarea"
                              name="announcement.Message"
                              placeholder="Write the announcement message here..."
                              required>@Model.Announcement?.Message</textarea>
                </div>

                <div class="admin-actions">
                    <button type="submit" class="admin-btn admin-btn-primary">Create</button>
                    <button type="reset" class="admin-btn admin-btn-secondary">Clear</button>
                </div>
            </form>
        </section>

        <section class="admin-panel">
            <div class="admin-panel-heading">
                <h2 class="admin-panel-title">Existing Announcements</h2>
                <p class="admin-panel-help">Use the controls below to update or delete announcements.</p>
            </div>

            @if (Model.Announcements == null || !Model.Announcements.Any())
            {
                <div class="admin-empty-state">
                    No announcements are available yet.
                </div>
            }
            else
            {
                <form method="post" action="/Admin/Announcements" class="admin-delete-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="action" value="delete" />

                    <div class="admin-announcement-list">
                        @for (var i = 0; i < Model.Announcements.Count; i++)
                        {
                            var announcement = Model.Announcements[i];

                            <label class="admin-delete-card">
                                <input type="checkbox" name="id" value="@announcement.Id" />
                                <span>
                                    <strong>@announcement.Title</strong>
                                    <small>@announcement.PostedDate.ToString("MMM dd, yyyy")</small>
                                </span>
                            </label>
                        }
                    </div>

                    <div class="admin-actions">
                        <button type="submit" class="admin-btn admin-btn-danger">Delete Selected</button>
                    </div>
                </form>

                <hr class="admin-divider" />

                <form method="post" action="/Admin/Announcements" class="admin-update-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="action" value="update" />

                    <div class="admin-edit-grid">
                        @for (var i = 0; i < Model.Announcements.Count; i++)
                        {
                            var announcement = Model.Announcements[i];

                            <article class="admin-edit-card">
                                <input type="hidden" name="announcements[@i].Id" value="@announcement.Id" />
                                <input type="hidden"
                                       name="announcements[@i].PostedDate"
                                       value="@announcement.PostedDate.ToString("o")" />

                                <div class="admin-card-meta">
                                    <span class="admin-badge">Announcement</span>
                                    <span class="admin-date">@announcement.PostedDate.ToString("MMMM dd, yyyy")</span>
                                </div>

                                <div class="admin-field">
                                    <label class="admin-label" for="announcements_@(i)__Title">Title</label>
                                    <input id="announcements_@(i)__Title"
                                           class="admin-input"
                                           type="text"
                                           name="announcements[@i].Title"
                                           value="@announcement.Title"
                                           required />
                                </div>

                                <div class="admin-field">
                                    <label class="admin-label" for="announcements_@(i)__Message">Message</label>
                                    <textarea id="announcements_@(i)__Message"
                                              class="admin-textarea"
                                              name="announcements[@i].Message"
                                              required>@announcement.Message</textarea>
                                </div>
                            </article>
                        }
                    </div>

                    <div class="admin-actions">
                        <button type="submit" class="admin-btn admin-btn-primary">Save Updates</button>
                    </div>
                </form>
            }
        </section>
    }
</div>
