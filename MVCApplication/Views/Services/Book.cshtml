@model MVCApplication.Models.AndInTheDarknessBindThem
@{
    ViewData["Title"] = "Book a Service";
}

@section Styles {
    <link rel="stylesheet" href="~/css/services.css" asp-append-version="true" />
}

<div class="services-container booking-form-container">
    <!-- Header -->
    <div class="services-header">
        <h1 class="services-title">📋 Book a Service</h1>
        <p class="services-subtitle">Fill out the form below to reserve your service</p>
    </div>

    <!-- Alert Messages -->
    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="alert error" id="serverError">
            <strong>⚠️ Error:</strong> @Model.Error
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.Success))
    {
        <div class="alert success">
            <strong>✓ Success:</strong> @Model.Success
        </div>
    }

    <div class="alert error" id="validationErrors" style="display: none;"></div>

    <!-- Booking Form -->
    <form method="post" action="/Services/Book" class="booking-form" id="bookingForm">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label for="FullName">
                Full Name <span class="required">*</span>
            </label>
            <input type="text"
                   id="FullName"
                   name="FullName"
                   placeholder="John Doe"
                   value="@Model.Booking?.FullName" />
            <span class="error-message" id="fullNameError"></span>
        </div>

        <div class="form-group">
            <label for="Email">
                Email Address <span class="required">*</span>
            </label>
            <input type="email"
                   id="Email"
                   name="Email"
                   placeholder="john.doe@example.com"
                   value="@Model.Booking?.Email" />
            <span class="error-message" id="emailError"></span>
        </div>

        <div class="form-group">
            <label for="BookingDate">
                Preferred Date <span class="required">*</span>
            </label>
            <input type="date"
                   id="BookingDate"
                   name="BookingDate"
                   value="@Model.Booking?.BookingDate.ToString("yyyy-MM-dd")" />
            <span class="error-message" id="bookingDateError"></span>
        </div>

        <div class="booking-actions">
            <button type="submit" class="btn-book">
                ✓ Submit Booking
            </button>
            <a href="/Services" class="btn-secondary">
                Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/validation-helpers.js"></script>
    <script src="~/js/booking-validation.js"></script>
}
