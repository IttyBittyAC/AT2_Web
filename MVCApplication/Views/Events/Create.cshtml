<!--Only for Admin-->
@model MVCApplication.Models.AndInTheDarknessBindThem
@{
    ViewData["Title"] = "Create Event";
}

@section Styles {
    <link rel="stylesheet" href="~/css/create-event.css" asp-append-version="true" />
}

<div class="create-event-container">
    <!-- Header -->
    <div class="create-event-header">
        <h1 class="create-event-title">📅 Create New Event</h1>
        <p class="create-event-subtitle">Share an event with your community</p>
    </div>

    <!-- Alert Messages -->
    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="alert error" id="serverError">
            <strong>⚠️ Error:</strong> @Model.Error
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.Success))
    {
        <div class="alert success">@Model.Success</div>
    }

    <div class="alert error" id="validationErrors" style="display: none;"></div>

    <!-- Info Box -->
    <div class="info-box">
        <p>
            <strong>💡 Tip:</strong> Make your event stand out with a clear title and detailed description.
            Include all important information so attendees know what to expect!
        </p>
    </div>

    <!-- Create Event Form -->
    <form method="post" action="/Events/Create" class="create-event-form" id="createEventForm">
        @Html.AntiForgeryToken()

        <!-- Event Title -->
        <div class="form-group">
            <label for="Title">
                Event Title
                <span class="required">*</span>
            </label>
            <input type="text"
                   id="Title"
                   name="Title"
                   placeholder="e.g., Community Barbecue, Book Club Meeting"
                   value="@Model.Event?.Title" />
            <span class="error-message" id="titleError"></span>
            <div class="form-helper">Minimum 5 characters, maximum 200</div>
        </div>

        <!-- Event Description -->
        <div class="form-group">
            <label for="Description">
                Event Description
            </label>
            <textarea id="Description"
                      name="Description"
                      placeholder="Describe your event in detail... What will happen? Who should attend? What should people bring?">@Model.Event?.Description</textarea>
            <span class="error-message" id="descriptionError"></span>
            <div id="descriptionCounter" class="char-counter">0 / 2000 characters</div>
        </div>

        <!-- Event Date & Time -->
        <div class="form-group">
            <label for="EventDate">
                Event Date & Time
                <span class="required">*</span>
            </label>
            <input type="datetime-local"
                   id="EventDate"
                   name="EventDate"
                   value="@(Model.Event?.EventDate.ToString("yyyy-MM-ddTHH:mm"))" />
            <span class="error-message" id="eventDateError"></span>
            <div class="form-helper">Select when your event will take place</div>
        </div>

        <!-- Event Location -->
        <div class="form-group">
            <label for="Location">
                Location
            </label>
            <input type="text"
                   id="Location"
                   name="Location"
                   placeholder="e.g., Community Hall, Main Street Park"
                   value="@Model.Event?.Location" />
            <span class="error-message" id="locationError"></span>
            <div class="form-helper">Where will the event be held?</div>
        </div>

        <!-- Form Actions -->
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">
                ✓ Create Event
            </button>
            <a href="/Events" class="btn btn-secondary">
                Cancel
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/validation-helpers.js"></script>
    <script src="~/js/create-event-validation.js"></script>
}