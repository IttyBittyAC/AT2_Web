@model MVCApplication.Models.AndInTheDarknessBindThem
@{
    ViewData["Title"] = "Feedback";
    var t = Model.Feedback?.Type ?? "";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Feedback.css" asp-append-version="true" />
}

<div class="feedback-container">
    <h1 class="FeedbackHeading">Share Your Feedback</h1>
    <h2 class="FeedbackSubHeading">We value your feedback! Please share your thoughts and suggestions with us.</h2>

    @if (!string.IsNullOrEmpty(Model.Error))
    {
        <div class="alert error" id="serverError">@Model.Error</div>
    }

    @if (!string.IsNullOrEmpty(Model.Success))
    {
        <div class="alert success">@Model.Success</div>
    }


    <div class="alert error" id="validationErrors" style="display: none;"></div>

    <form method="post" action="/Feedback" id="feedbackForm">
        @Html.AntiForgeryToken()

        <!-- Feedback Type Section -->
        <div class="form-section">
            <div class="field">
                <label for="Type">Feedback Type *</label>
                <select name="Type" id="Type">
                    <option value="">— Please select —</option>
                    <option value="Experience" selected="@(t == "Experience" ? "selected" : null)">Experience with the website</option>
                    <option value="ProductSatisfaction" selected="@(t == "ProductSatisfaction" ? "selected" : null)">Product Satisfaction</option>
                    <option value="Support" selected="@(t == "Support" ? "selected" : null)">Support</option>
                    <option value="Bugs" selected="@(t == "Bugs" ? "selected" : null)">Bug report</option>
                    <option value="Other" selected="@(t == "Other" ? "selected" : null)">Other</option>
                </select>
                <span class="error-message" id="typeError"></span>
            </div>
        </div>

        <!-- Feedback Details Section -->
        <div class="form-section">
            <div class="field">
                <label for="Heading">Subject *</label>
                <input type="text"
                       id="Heading"
                       name="Heading"
                       placeholder="Brief summary of your feedback"
                       value="@Model.Feedback?.Heading" />
                <span class="error-message" id="headingError"></span>
            </div>

            <div class="field">
                <label for="Message">Your Feedback *</label>
                <textarea id="Message"
                          name="Message"
                          placeholder="Tell us how we can improve...">@Model.Feedback?.Message</textarea>
                <span class="error-message" id="messageError"></span>
            </div>
        </div>

        <!-- Contact Information Section -->
        <div class="form-section">
            <h3>Contact Information</h3>

            <div class="field">
                <label for="FullName">Full Name *</label>
                <input type="text"
                       id="FullName"
                       name="FullName"
                       placeholder="John Doe"
                       value="@Model.Feedback?.FullName" />
                <span class="error-message" id="fullnameError"></span>
            </div>

            <div class="field">
                <label for="Email">Email Address *</label>
                <input type="email"
                       id="Email"
                       name="Email"
                       placeholder="john.doe@example.com"
                       value="@Model.Feedback?.Email" />
                <span class="error-message" id="emailError"></span>
            </div>
        </div>

        <!-- Contact Preference Section -->
        <div class="form-section">
            <h3>Would you like us to contact you?</h3>
            <p>We can let you know if we have addressed your feedback</p>

            <div class="radio-group">
                <div class="radio-option">
                    <input type="radio"
                           id="contactYes"
                           name="WantsContact"
                           value="true"
                           @(Model.Feedback?.WantsContact == true ? "checked" : "") />
                    <label for="contactYes">Yes, please contact me</label>
                </div>

                <div class="radio-option">
                    <input type="radio"
                           id="contactNo"
                           name="WantsContact"
                           value="false"
                           @(Model.Feedback?.WantsContact == false ? "checked" : "") />
                    <label for="contactNo">No, thank you</label>
                </div>
            </div>
        </div>

        <button type="submit" class="submit-button">Submit Feedback</button>
    </form>
</div>

@section Scripts {
    <script src="~/js/validation-helpers.js"></script>
    <script src="~/js/feedback-validation.js"></script>
}