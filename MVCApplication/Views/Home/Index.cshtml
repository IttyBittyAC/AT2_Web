@model MVCApplication.Models.AndInTheDarknessBindThem
@using System.Linq

@{
    ViewData["Title"] = "Home Page";
    Layout = "_Layout";
}

<div class="home-wrapper">

    <!-- Community Dashboard -->
    <section class="dashboard">
        <h2>Community Dashboard</h2>
        <p>
            Home Page, you can view events, announcements and contact info here.
        </p>
    </section>

    <!-- Two Column Section -->
    <section class="info-section">
        <div class="info-card">
            <h3>Announcements</h3>
            <ul>
                <li>Some text here</li>
                <li>Some text here</li>
                <li>Some text here</li>
            </ul>
        </div>

        <div class="info-card">
            <h3>Events</h3>
            @if (Model.Events != null && Model.Events.Any())
            {
                <ul>
                    @foreach (var evt in Model.Events)
                    {
                        <li>
                            <strong>@evt.Title</strong><br />
                            <small>@evt.EventDate.ToString("MMM dd, yyyy")</small><br />
                            @evt.Description
                        </li>
                    }
                </ul>
            }
            else
            {
                <ul>
                    <li>No upcoming events</li>
                </ul>
            }
        </div>
    </section>
    <br/>
    <!-- Contact -->
    <section class="contact">
        <h2>Contact Us</h2>
        <p>Contact Number: 04 1234 5678</p>
        <p>Contact Email: THESONOFGOD@DontWorryAboutIt.com</p>
    </section>

</div>