@model MVCApplication.Models.AndInTheDarknessBindThem
@using System.Linq

@{
    ViewData["Title"] = "Home Page";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<div class="home-wrapper">

    <!-- Community Dashboard -->
    <section class="dashboard">
        <h2>Community Dashboard</h2>
        <p>
            Home Page, you can view events, announcements and contact info here.
        </p>
    </section>

    <!-- Two Column Section -->
    <section class="info-section">
        <div class="info-card">
            <h3>Announcements</h3>
            <div class="announcements-list">
                @if (Model.Announcements != null && Model.Announcements.Any())
                {
                    foreach (var announcement in Model.Announcements.OrderByDescending(a => a.PostedDate))
                    {
                        <div class="announcement-card">
                            <div class="announcement-header">
                                <span class="announcement-badge announcement-badge-general">General</span>
                                <span class="announcement-date">@announcement.PostedDate.ToString("MMMM d, yyyy")</span>
                            </div>
                            <h2 class="announcement-title">@announcement.Title</h2>
                            <div class="announcement-body">
                                @foreach (var line in (announcement.Message ?? string.Empty)
                                                        .Split(new[] { "\r\n", "\n" }, StringSplitOptions.None))
                                {
                                    if (!string.IsNullOrWhiteSpace(line))
                                    {
                                        <p>@line</p>
                                    }
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="announcement-card">
                        <div class="announcement-body">
                            <p>No announcements are available right now.</p>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="info-card">
            <h3>Events</h3>
            <!-- Events Grid -->
            @if (Model.Events != null && Model.Events.Any())
            {
                <div class="events-grid">
                    @foreach (var evt in Model.Events)
                    {
                        <div class="event-card">
                            <!-- Card Header -->
                            <div class="event-card-header">
                                <h2 class="event-card-title">@evt.Title</h2>
                            </div>

                            <!-- Card Body -->
                            <div class="event-card-body">
                                <p class="event-description">
                                    @if (evt.Description.Length > 150)
                                    {
                                        @evt.Description.Substring(0, 150)
                            
                                        <text>...</text>
                                    }
                                    else
                                    {
                                        @evt.Description
                                    }
                                </p>

                                <!-- Event Meta Information -->
                                <div class="event-meta">
                                    <div class="event-meta-item">
                                        <span class="event-meta-icon">🗓️</span>
                                        <span class="event-meta-text event-date">
                                            @evt.EventDate.ToString("MMMM dd, yyyy 'at' h:mm tt")
                                        </span>
                                    </div>

                                    <div class="event-meta-item">
                                        <span class="event-meta-icon">📍</span>
                                        <span class="event-meta-text event-location">
                                            @evt.Location
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <!-- Card Footer -->
                            <div class="event-card-footer">
                                <a href="/Events/Details/@evt.Id" class="btn-view-details">
                                    View Details →
                                </a>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <!-- Empty State -->
                <div class="empty-state">
                    <p>There are currently no upcoming events. Check back soon!</p>
                    @if (Model.IsAuth)
                    {
                        <a href="/Events/Create" class="btn-create-event">
                            Be the first to create an event!
                        </a>
                    }
                </div>
            }
        </div>
    </section>

    <br />

    <!-- Contact -->
    <section class="contact">
        <h2>Contact Us</h2>
        <p>Contact Number: 04 1234 5678</p>
        <p>Contact Email: contact@citylinkinitiatives.gov.au</p>
    </section>

</div>